# ============================================================
#  Local LLM Stack — 環境變數設定
#  複製此檔案為 .env 並填入你的設定
#  cp .env.example .env
# ============================================================


# ── 必填：LiteLLM 主要 API Key ────────────────────────────
# 這是你自定義的本地 Key，VSCode Claude Code Plugin 使用此 Key
# 格式必須是 sk- 開頭，自己取名即可，不需要向任何服務申請
LITELLM_MASTER_KEY=sk-local-dev-2025

# ── 必填：Open WebUI 密鑰 ─────────────────────────────────
# 用於加密 session，隨機產生一串字串即可
# 可用此指令生成：openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-random-secret-string


# ── 可選：OpenAI API Key（備援雲端模型）──────────────────
# 如果你有 OpenAI Key，可以在本地模型不夠時自動 fallback
# 申請：https://platform.openai.com/api-keys
# 留空或填 placeholder 代表不使用
OPENAI_API_KEY=placeholder


# ── 可選：Anthropic API Key（備援 Claude Cloud）──────────
# 如果你有 Anthropic Key，可以設定 fallback 到 Claude Cloud
# 申請：https://console.anthropic.com/
# 留空或填 placeholder 代表不使用
ANTHROPIC_API_KEY=placeholder


# ── 連接埠設定（有衝突才需改）────────────────────────────
OLLAMA_PORT=11434        # Ollama API 連接埠
LITELLM_PORT=4000        # LiteLLM Proxy 連接埠（VSCode 指向此埠）
WEBUI_PORT=8080          # Open WebUI 管理介面連接埠


# ── Ollama 效能調整 ───────────────────────────────────────
# 模型在 VRAM 中保留時間（避免重複載入）
# 值：30m / 1h / 24h / -1（永不卸載）
OLLAMA_KEEP_ALIVE=24h

# 同時在 VRAM 中保留的最大模型數量
# 48GB VRAM 建議設 3（可同時跑 nemotron-super + gemma2-27b + codegemma）
OLLAMA_MAX_LOADED=3

# 並行處理請求數（每個模型）
OLLAMA_NUM_PARALLEL=2
